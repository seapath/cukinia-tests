passwd=" \
    admin \
    ansible \
    _apt \
    backup \
    bin \
    ceph \
    _chrony \
    daemon \
    Debian-snmp \
    dnsmasq \
    games \
{% if inventory_hostname in groups['cluster_machines'] %}
    hacluster \
{% endif %}
    irc \
    libvirt \
    libvirt-qemu \
    list \
    livemigration \
    lp \
    mail \
    man \
    messagebus \
    news \
    nobody \
    polkitd \
    proxy \
    root \
    sshd \
    sync \
    sys \
    systemd-network \
    systemd-resolve \
    uucp \
    uuidd \
    www-data \
"
args="-v"
for g in ${passwd}; do
    args="$args -e $g"
done

cukinia_log "$(_colorize yellow "--- check /etc/passwd ---")"
nb_passwd=$(echo $passwd | wc -w)
id "SEAPATH-00047" as "/etc/passwd is consistent" cukinia_test $(grep $args /etc/passwd | wc -l) -eq 0
id "SEAPATH-00048" as "/etc/passwd does not include extra user" cukinia_test $(cat /etc/passwd | wc -l) -eq $nb_passwd
